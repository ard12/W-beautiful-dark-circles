# SENTINEL — Environment Configuration
# Copy this file to .env and fill in your values.

# Anthropic API key for AI reasoning layer
AI_API_KEY=your_anthropic_api_key_here

# Model to use for AI reasoning (default: claude-sonnet-4-20250514)
AI_MODEL=claude-sonnet-4-20250514

# Backend server port
BACKEND_PORT=8000

# Frontend dev server port
FRONTEND_PORT=5173

# Set to "true" to use pre-authored fallback responses instead of live AI
# Use this if: API is unreliable, rate-limited, or during demo as insurance
FALLBACK_MODE=false

# Supabase — auth and optional persistence
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
